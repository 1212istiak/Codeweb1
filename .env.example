# ─── MongoDB ───────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/rockstarz
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/rockstarz
MONGO_URI=mongodb://localhost:27017/rockstarz

# ─── JWT Secret (change this to a long random string) ──────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_string_123

# ─── Admin password ────────────────────────────────────────────────
ADMIN_PASSWORD=rockstarz

# ─── Port ──────────────────────────────────────────────────────────
PORT=3000

# ─── Image Storage ─────────────────────────────────────────────────
# Set to "local" for development, "cloudinary" for production
IMAGE_STORAGE=local

# ─── Cloudinary (only needed if IMAGE_STORAGE=cloudinary) ──────────
# Get free account at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
